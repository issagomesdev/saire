##
## .env.example
##
## Pronto para uso com Docker (padrão recomendado — veja "Docker
## Environment" no README): copie para ".env" e rode `docker compose up -d`.
## Também é lido pelo docker-compose.yml/docker-compose.prod.yml para
## interpolar variáveis como ${APP_PORT} — um único arquivo evita manter
## a mesma configuração duplicada entre app e infraestrutura.
##
## Rodando SEM Docker (PHP/Composer/MySQL nativos na máquina)? Os
## comentários "sem Docker:" abaixo indicam exatamente o que trocar.
##

APP_NAME=Saire
APP_ENV=local
APP_KEY=
APP_DEBUG=true
# sem Docker: APP_URL=http://localhost
APP_URL=http://localhost:${APP_PORT}

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

## --------------------------------------------------------------------
## Porta HTTP publicada no host pelo Nginx (docker-compose*.yml). Altere
## apenas este valor para evitar conflito com outros projetos Docker na
## mesma VPS/maquina — nenhum arquivo docker* precisa mudar. Sem efeito
## se voce nao usa Docker (o `artisan serve` usa sua propria porta).
## --------------------------------------------------------------------
APP_PORT=8000

## Portas dos demais servicos expostas no host. So sao usadas pelo
## docker-compose.yml (desenvolvimento); em producao o MySQL e o Redis
## nao ficam expostos publicamente por padrao (ver docker-compose.prod.yml).
FORWARD_DB_PORT=3306
FORWARD_REDIS_PORT=6379
VITE_PORT=5173

DB_CONNECTION=mysql
# sem Docker: DB_HOST=127.0.0.1
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=saire
DB_USERNAME=saire
DB_PASSWORD=secret

## Usada apenas pelo container mysql (docker-compose*.yml) para criar o
## usuario root do banco. Nao e lida pelo Laravel. Sem efeito se voce
## nao usa Docker.
MYSQL_ROOT_PASSWORD=root_secret

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

MEMCACHED_HOST=127.0.0.1

## O container "redis" ja sobe junto com o projeto (Docker), pronto para
## uso futuro. Os drivers acima permanecem em file/sync para nao alterar
## o comportamento atual da aplicacao. Para habilitar o Redis:
##   1. composer require predis/predis
##   2. mude CACHE_DRIVER, SESSION_DRIVER e/ou QUEUE_CONNECTION para "redis"
# sem Docker: REDIS_HOST=127.0.0.1
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https
PUSHER_APP_CLUSTER=mt1

VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_HOST="${PUSHER_HOST}"
VITE_PUSHER_PORT="${PUSHER_PORT}"
VITE_PUSHER_SCHEME="${PUSHER_SCHEME}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

## --------------------------------------------------------------------
## Somente producao: ajuste antes de subir docker-compose.prod.yml
## --------------------------------------------------------------------
# APP_ENV=production
# APP_DEBUG=false
# APP_URL=https://seu-dominio.com.br
# RUN_MIGRATIONS=false
