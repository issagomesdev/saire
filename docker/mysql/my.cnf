# docker/mysql/my.cnf
# Charset/collation alinhados com config/database.php (utf8mb4_unicode_ci)
# e autenticacao compativel com clientes PHP mysqlnd mais antigos.

[mysqld]
character-set-server = utf8mb4
collation-server = utf8mb4_unicode_ci
default-authentication-plugin = mysql_native_password

max_connections = 200
innodb_buffer_pool_size = 256M

[client]
default-character-set = utf8mb4
