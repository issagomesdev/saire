# Segredos: nunca devem ser copiados para dentro de uma imagem
.env
.env.backup
.env.production
.env.docker
!.env.example

# Reconstruidos dentro da imagem (composer install / npm run build)
vendor
node_modules
public/build
public/hot

# Gerado por "artisan storage:link" ao rodar o container de dev com o
# codigo em bind mount: vira um symlink real no host apontando para um
# caminho absoluto que so existe dentro do container, e quebra o
# contexto de build da imagem de producao ("invalid file request").
public/storage

# Nao usados em runtime
tests
.phpunit.cache
phpunit.xml
README.md
images
banners.pen
estrutura.txt

# NAO excluir database/fake_media (~280MB) apesar do tamanho: PagesSeeder,
# PublicationsSeeder e GalleriesSeeder leem arquivos de la incondicionalmente
# (ex.: fake_media/governo_municipal/prefeita.png), e "db:seed"/"migrate
# --seed" tambem sao o fluxo oficial de populacao em producao (ver README >
# Database Seeding) -- ja excluir essa pasta aqui quebrou "artisan db:seed"
# com FileDoesNotExist. Se um dia esse acervo for so decorativo/dev-only de
# fato, mover a decisao para os seeders (ex.: pular fotos quando ausentes),
# nao esconder o arquivo do build context.

docker-compose.yml
docker-compose.prod.yml
